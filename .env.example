# Copy this file to .env.local and fill in your values
# Get Supabase credentials from: Supabase Dashboard > Project Settings > API Keys

REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Portal URL — update this when your custom domain goes live
# During development / Vercel staging:
REACT_APP_PORTAL_URL=https://loanmoneyfest.vercel.app/portal
# When custom domain is live, change to:
# REACT_APP_PORTAL_URL=https://moneyfestlending.online/portal
